# Copia a .env (gitignored) para pruebas locales. En producción se usan GitHub Secrets.

# Base del ERP donde viven los endpoints de importación
IMPORT_BASE=https://binagre.vercel.app

# Secreto opcional para autenticar la importación (cabecera x-scraper-secret).
# Dejar vacío hasta activar la verificación en el endpoint.
IMPORT_SECRET=

# Portales a ejecutar (coma-separados). Por defecto todos.
SCRAPER_PORTALES=uber,glovo,justeat,rushour,bbva

# storageState (cookies de sesión) en base64. Se generan con `npm run login <portal>`.
# En local puedes usar los ficheros .sesiones/<portal>.json en vez de estas variables.
UBER_STORAGE_STATE=
GLOVO_STORAGE_STATE=
JUSTEAT_STORAGE_STATE=
RUSHOUR_STORAGE_STATE=
BBVA_STORAGE_STATE=
