+++ b/src/pages/Conciliacion.tsx
@@ -221,13 +221,25 @@ export default function Conciliacion() {
   const [reglas, setReglas] = useState<Regla[]>([])
 
   /* — Aplicar reglas existentes a movimientos recién importados — */
+  function matchPatron(concepto: string, patron: string): boolean {
+    if (!patron) return false
+    const c = concepto.toLowerCase()
+    const p = patron.toLowerCase()
+    // Si no contiene wildcards, match por inclusión
+    if (!p.includes('*') && !p.includes('?')) return c.includes(p)
+    // Convertir wildcards a regex: * = .*, ? = .
+    const esc = p.replace(/[.+^${}()|[\]\\]/g, '\\$&')
+    const rx = new RegExp('^' + esc.replace(/\*/g, '.*').replace(/\?/g, '.') + '$')
+    return rx.test(c)
+  }
+
   function aplicarReglasExistentes(nuevos: Movimiento[]) {
     void nuevos
     if (reglas.length === 0) return
     setMovimientos(prev => prev.map(m => {
       if (m.categoria_id) return m
       for (const r of reglas) {
-        if (m.concepto.toLowerCase().includes(r.patron.toLowerCase())) {
+        if (matchPatron(m.concepto, r.patron)) {
           return { ...m, categoria_id: r.categoria_id, auto_categorizado: true }
         }
       }
