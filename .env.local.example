# Copia este fichero a .env.local y rellena los valores.
# Estas env vars son necesarias para que los endpoints /api/* funcionen en el dev server local (npm run dev).
# En Vercel producción ya están configuradas, esto es SOLO para desarrollo local.

# Supabase (service role para funciones serverless del lado API)
SUPABASE_URL=https://eryauogxcpbgdryeimdq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Vars del frontend (Vite necesita prefijo VITE_)
VITE_SUPABASE_URL=https://eryauogxcpbgdryeimdq.supabase.co
VITE_SUPABASE_ANON_KEY=

# Google Drive (para subirADrive en /api/facturas/upload y /api/facturas/[id]/confirmar)
# Pega el JSON completo de la service account en UNA línea
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# OCR Anthropic (opcional para extracción de facturas)
ANTHROPIC_API_KEY=

# Google OAuth (Drive por usuario real, reemplaza Service Account)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/api/oauth/google/callback
